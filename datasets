import random
import torch
from torch.utils.data import Dataset
from collections import defaultdict
import copy
import numpy as np


class DMMD4SRDataset(Dataset):
    def __init__(self, args, user_seq, test_neg_items=None, data_type="train"):
        self.args = args
        self.user_seq = user_seq
        self.test_neg_items = test_neg_items
        self.data_type = data_type
        self.max_len = args.max_seq_length
        
        # Create user_train, user_valid, user_test
        self.user_train = {}
        self.user_valid = {}
        self.user_test = {}
        self.train_item_dict = defaultdict(set)
        
        for user_id, seq in user_seq.items():
            if len(seq) < 3:
                self.user_train[user_id] = seq
                self.user_valid[user_id] = []
                self.user_test[user_id] = []
            else:
                self.user_train[user_id] = seq[:-2]
                self.user_valid[user_id] = [seq[-2]]
                self.user_test[user_id] = [seq[-1]]
            
            for item in self.user_train[user_id]:
                self.train_item_dict[user_id].add(item)
        
        self.samples = []
        for user_id in user_seq.keys():
            if len(self.user_train[user_id]) < 1:
                continue
            
            if data_type == "train":
                if len(self.user_train[user_id]) < 2:
                    continue
                input_seq = self.user_train[user_id][:-1]
                target = self.user_train[user_id][-1]
            elif data_type == "valid":
                if not self.user_valid[user_id]:
                    continue
                input_seq = self.user_train[user_id]
                target = self.user_valid[user_id][0]
            else:  # test
                if not self.user_test[user_id]:
                    continue
                valid_seq = self.user_valid[user_id] if self.user_valid[user_id] else []
                input_seq = self.user_train[user_id] + valid_seq
                target = self.user_test[user_id][0]
            
            self.samples.append((user_id, input_seq, target))
        
        self.num_items = args.item_size

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, index):
        user_id, input_seq, target = self.samples[index]
        
        # Negative sampling for training
        rated = self.train_item_dict[user_id] | {target}
        neg = np.random.randint(1, self.num_items)
        while neg in rated:
            neg = np.random.randint(1, self.num_items)
        
        # Padding/truncating sequence
        seq = input_seq[-self.max_len:]
        seq_len = len(seq)
        pad_len = self.max_len - seq_len
        
        item_ids = [0] * pad_len + seq
        item_ids = item_ids[-self.max_len:]
        
        assert len(item_ids) == self.max_len
        
        return {
            'user_id': torch.tensor(user_id, dtype=torch.long),
            'item_ids': torch.tensor(item_ids, dtype=torch.long),
            'target': torch.tensor(target, dtype=torch.long),
            'negative': torch.tensor(neg, dtype=torch.long),
        }
